# Serverless（api/gemini 等）：本地用 `npx vercel dev` / `npm run dev:api` 时会读取本目录 .env.local；线上在 Vercel 环境变量中配置。
GEMINI_API_KEY=

# 仅当前端与 API 不同域时填写（不要尾斜杠）。同源（如 modcard.asia）切勿填本站域名，否则易 404；同源请留空
# VITE_API_BASE_URL=https://国内或主站-api-域名

# 前端托管在国内、无法直连 Google 时：仅让 Gemini 走海外 Vercel（须与上面分离）。不设则与 VITE_API_BASE_URL / 同源相同
# VITE_GEMINI_API_BASE_URL=https://你的项目.vercel.app

COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=

VITE_CLOUDBASE_ENV_ID=
VITE_CLOUDBASE_ACCESS_KEY=

# 开屏 BGM（二选一或同时配置：直连优先于云存储）
# 直连 MP3 地址（推荐，避免 getTempFileURL / 环境不一致）：部署后务必设置为你站点上的真实文件 URL
# VITE_LANDING_MUSIC_URL=https://你的域名/path/to/bgm.mp3
# 云存储 fileID，逗号分隔按顺序尝试；不设则尝试 cloud://$VITE_CLOUDBASE_ENV_ID/music/ 与 cloud://lokada-1254090729/music/ 下 bgm/opening/landing.mp3
# VITE_LANDING_MUSIC_FILE_IDS=cloud://lokada-1254090729/music/your-track.mp3

# 三视图 / 3D 手电筒页底图（可选；不设则用 public/developing-hero-bg.jpg）
# VITE_DEVELOPING_HERO_BG=https://你的CDN/hero.jpg

UPSCAYL_API_KEY=
