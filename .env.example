# Serverless（api/gemini 等）：本地用 `npx vercel dev` / `npm run dev:api` 时会读取本目录 .env.local；线上在 Vercel 环境变量中配置。
GEMINI_API_KEY=

# 仅当前端与 API 不同域时填写（不要尾斜杠）。同源（如 modcard.asia）切勿填本站域名，否则易 404；同源请留空
# VITE_API_BASE_URL=https://另一个-api-域名.vercel.app

COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=

VITE_CLOUDBASE_ENV_ID=
VITE_CLOUDBASE_ACCESS_KEY=

UPSCAYL_API_KEY=
